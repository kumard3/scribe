---
import { REPO, RELEASES } from '../consts';
---
<section class="final">
  <div class="wrap">
    <h2 class="reveal">Speak freely.<br>Keep it yours.</h2>
    <p class="reveal">Free, offline, and open. Install Scribe and your words never have to trust a server again.</p>
    <div class="hero-cta reveal">
      <a class="btn btn-primary btn-lg" href={RELEASES}>Download for Android</a>
      <a class="btn btn-ghost btn-lg" href={REPO}>Star on GitHub</a>
    </div>
  </div>
</section>
