---
import Base from '../layouts/Base.astro';
import Icon from '../components/Icon.astro';
---
<Base title="Not found · Scribe" anchors={false}>
  <main class="wrap prose" style="text-align:center">
    <div class="kicker" style="justify-content:center">404</div>
    <h1>Nothing here.</h1>
    <p style="margin-left:auto;margin-right:auto">This page didn't make it onto your device, or anyone else's.</p>
    <a class="back" href="/" style="justify-content:center"><Icon name="back" /> Back to home</a>
  </main>
</Base>
