---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import TrustStrip from '../components/TrustStrip.astro';
import Stats from '../components/Stats.astro';
import Features from '../components/Features.astro';
import Integrations from '../components/Integrations.astro';
import HowItWorks from '../components/HowItWorks.astro';
import UseCases from '../components/UseCases.astro';
import Compare from '../components/Compare.astro';
import PrivacyManifesto from '../components/PrivacyManifesto.astro';
import Faq from '../components/Faq.astro';
import Platforms from '../components/Platforms.astro';
import FinalCTA from '../components/FinalCTA.astro';
import { softwareAppSchema, webSiteSchema, faqSchema } from '../lib/seo';
---
<Base schemas={[softwareAppSchema, webSiteSchema, faqSchema]}>
  <main id="top">
    <Hero />
    <TrustStrip />
    <Stats />
    <Features />
    <Integrations />
    <HowItWorks />
    <UseCases />
    <Compare />
    <PrivacyManifesto />
    <Faq />
    <Platforms />
    <FinalCTA />
  </main>
</Base>
